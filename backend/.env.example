# PostgreSQL container initialization (used by docker-compose postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ubuntu_auth_log

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ubuntu_auth_log

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Log Reader
LOG_FILE_PATH=/var/log/auth.log
LOG_OFFSET_FILE_PATH=/state/.log_offset
LOG_READER_INTERVAL_MINUTES=1
LOG_READER_INITIAL_DAYS=2
LOG_READER_LARGE_FILE_MB=20

# API
API_PREFIX=/api
API_V1_PREFIX=/api/v1

# Environment
ENVIRONMENT=production
DEBUG=false
